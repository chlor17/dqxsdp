bundle:
  name: dqx-pipeline

sync:
  include:
    - config.yaml

variables:
  catalog:
    default: your_catalog
  schema:
    default: your_schema

targets:
  dev:
    mode: development
    default: true
    workspace:
      host: https://your-workspace.cloud.databricks.com
      profile: your-profile
      file_path: /Workspace/Users/your-email@example.com/dqx

resources:

  # ── Silver SDP pipeline ────────────────────────────────────────────────────
  pipelines:
    silver_scd2:
      name: dqx-silver-scd2
      catalog: ${var.catalog}
      schema:  ${var.schema}
      serverless: true
      configuration:
        Catalog:      ${var.catalog}
        Schema:       ${var.schema}
        Bronze_table: bronze_table
      libraries:
        - file:
            path: ./SilverTableDP.py

  # ── Jobs ──────────────────────────────────────────────────────────────────
  jobs:

    # Production — full load (weekly)
    full_load:
      name: dqx-full-load
      tasks:
        - task_key: full_load
          notebook_task:
            notebook_path: ./LandingZoneBronze.py
            base_parameters:
              load_type: full
        - task_key: silver
          depends_on:
            - task_key: full_load
          pipeline_task:
            pipeline_id: ${resources.pipelines.silver_scd2.id}
        - task_key: summary
          depends_on: [{task_key: silver}]
          notebook_task:
            notebook_path: ./SummaryMetrics.py

    # Production — partial load (every 6h)
    partial_load:
      name: dqx-partial-load
      tasks:
        - task_key: partial_load
          notebook_task:
            notebook_path: ./LandingZoneBronze.py
            base_parameters:
              load_type: partial
        - task_key: silver
          depends_on:
            - task_key: partial_load
          pipeline_task:
            pipeline_id: ${resources.pipelines.silver_scd2.id}
        - task_key: summary
          depends_on: [{task_key: silver}]
          notebook_task:
            notebook_path: ./SummaryMetrics.py

    # Single parameterised scenario run — one write → bronze → silver per execution
    # Run with: databricks bundle run scenario_run --profile <profile> \
    #             -p step=2 -p load_type=partial
    scenario_run:
      name: dqx-scenario-run
      parameters:
        - name: step
          default: "1"
        - name: load_type
          default: full
      tasks:
        - task_key: write
          notebook_task:
            notebook_path: ./WriteTestData.py
            base_parameters:
              step:      "{{job.parameters.step}}"
              load_type: "{{job.parameters.load_type}}"
        - task_key: bronze
          depends_on: [{task_key: write}]
          notebook_task:
            notebook_path: ./LandingZoneBronze.py
            base_parameters:
              load_type: "{{job.parameters.load_type}}"
        - task_key: silver
          depends_on: [{task_key: bronze}]
          pipeline_task:
            pipeline_id: ${resources.pipelines.silver_scd2.id}
        - task_key: summary
          depends_on: [{task_key: silver}]
          notebook_task:
            notebook_path: ./SummaryMetrics.py
